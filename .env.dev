# Dokploy Development Environment Configuration

# Database Configuration
DATABASE_URL=postgres://dokploy:amukds4wi9001583845717ad2@dokploy-postgres-dev:5432/dokploy

# Redis Configuration  
REDIS_HOST=dokploy-redis-dev
REDIS_URL=redis://dokploy-redis-dev:6379

# Application Configuration
PORT=3000
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true

# Traefik Configuration
TRAEFIK_DASHBOARD_URL=http://localhost:8080

# Application URLs
DOKPLOY_URL=http://dokploy.localhost
MONITORING_URL=http://monitoring.localhost

# Security (Development Keys - Change for Production!)
JWT_SECRET=dev-jwt-secret-key
NEXTAUTH_SECRET=dev-nextauth-secret-key  
NEXTAUTH_URL=http://dokploy.localhost
BETTER_AUTH_SECRET=dev-better-auth-secret-key-make-it-long-and-secure

# OAuth Providers (Optional - configure if needed)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Development Debugging
DEBUG=dokploy:*
LOG_LEVEL=debug

# Hot Reloading Configuration
FAST_REFRESH=true
TURBOPACK=1

# Email Configuration (Development - use mailtrap or similar)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=dev@dokploy.local

# Monitoring Configuration
METRICS_CONFIG={"server":{"type":"monitoring","refreshRate":10,"port":3001,"token":"dev-monitoring-token","urlCallback":"http://dokploy-app-dev:3000/api/monitoring/callback","cronJob":"0 */1 * * *","retentionDays":7,"thresholds":{"cpu":80,"memory":80}},"containers":{"refreshRate":10,"services":{"include":["*"],"exclude":[]}}}

# File Upload Configuration (Development)
MAX_FILE_SIZE=50MB
UPLOAD_DIR=/tmp/dokploy-uploads

# Development Features
ENABLE_DEV_TOOLS=true
ENABLE_MOCK_DATA=true
ENABLE_DEBUG_LOGS=true